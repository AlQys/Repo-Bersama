#include <iostream>
using namespace std;

void tampilMenu() {
    cout << "=============================\n";
    cout << " SISTEM BOOKING HOTEL\n";
    cout << "=============================\n";
    cout << "1. Login\n";
    cout << "2. Register\n";
    cout << "3. Lihat Kamar\n";
    cout << "4. Booking\n";
    cout << "5. Keluar\n";
    cout << "=============================\n";
    cout << "Pilih menu: ";
}

int main() {
    int pilihan;

    do {
        tampilMenu();
        cin >> pilihan;

        switch(pilihan) {
            case 1:
                cout << "Menu Login dipilih\n";
                break;
            case 2:
                cout << "Menu Register dipilih\n";
                break;
            case 3:
                cout << "Menu Lihat Kamar\n";
                break;
            case 4:
                cout << "Menu Booking\n";
                break;
            case 5:
                cout << "Terima kasih!\n";
                break;
            default:
                cout << "Pilihan tidak valid!\n";
        }

    } while(pilihan != 5);

    return 0;
}
